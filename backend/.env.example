ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional debate cost controls (safe defaults shown)
ANTHROPIC_DEBATE_MODEL=claude-haiku-4-5
ANTHROPIC_DEBATE_BULLBEAR_MAX_TOKENS=140
ANTHROPIC_DEBATE_ARBITER_MAX_TOKENS=220
ANTHROPIC_DEBATE_TOTAL_OUTPUT_TOKEN_BUDGET=1000
ANTHROPIC_DEBATE_MAX_FINANCIAL_LINES=12
ANTHROPIC_DEBATE_MAX_THESIS_CHARS=700
ANTHROPIC_DEBATE_PROMPT_TAIL_CHARS=1800

# Owner bypass for rate limits. Set to a long random string and mirror it on
# the frontend as VITE_OWNER_KEY. Requests with a matching `x-owner-key` header
# skip the 7/day analyze cap, lookup cap, and search cap.
OWNER_KEY=replace-with-a-long-random-secret
